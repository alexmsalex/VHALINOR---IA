def verificar_configuracao() -> Dict[str, Any]:
    """
    Verifica a configuração completa do módulo de aprendizado.
    
    Returns:
        Dicionário com status detalhado do módulo
    """
    status = {
        'versao': __version__,
        'dependencias': _dependencies_status,
        'modulos_disponiveis': {
            'AprendizadoContinuo': _APRENDIZADO_CONTINUO_AVAILABLE,
            'AprendizadoEvolucional': _APRENDIZADO_EVOLUCIONAL_AVAILABLE,
        },
        'caminho_modulo': str(Path(__file__).parent.absolute()),
        'factory_singleton': SistemaAprendizadoFactory._use_singleton,
    }
    
    if _APRENDIZADO_CONTINUO_AVAILABLE and AprendizadoContinuo is not None:
        status['AprendizadoContinuo_versao'] = getattr(AprendizadoContinuo, '__version__', 'N/A')
    
    if _APRENDIZADO_EVOLUCIONAL_AVAILABLE and AprendizadoEvolucional is not None:
        status['AprendizadoEvolucional_versao'] = getattr(AprendizadoEvolucional, '__version__', 'N/A')
    
    return status


def inicializar_sistema_aprendizado(config: Optional[Dict[str, Any]] = None) -> Dict[str, Any]:
    """
    Inicializa todos os sistemas de aprendizado disponíveis.
    
    Args:
        config: Dicionário de configuração com chaves 'continuo', 'evolucional', etc.
        
    Returns:
        Dicionário com os sistemas inicializados.
    """
    config = config or {}
    
    sistemas = {}
    
    if _APRENDIZADO_CONTINUO_AVAILABLE:
        sistemas['continuo'] = SistemaAprendizadoFactory.criar_sistema('continuo', config.get('continuo'))
        _logger.info("Sistema de Aprendizado Contínuo inicializado")
    
    if _APRENDIZADO_EVOLUCIONAL_AVAILABLE:
        sistemas['evolucional'] = SistemaAprendizadoFactory.criar_sistema('evolucional', config.get('evolucional'))
        _logger.info("Sistema de Aprendizado Evolucional inicializado")
    
    if len(sistemas) == 2:
        sistemas['hibrido'] = SistemaAprendizadoFactory.criar_sistema_hibrido(
            config_continuo=config.get('continuo'),
            config_evolucional=config.get('evolucional')
        )
        _logger.info("Sistema de Aprendizado Híbrido inicializado")
    
    return sistemas


# Decoradores utilitários
F = TypeVar('F', bound=Callable[..., Any])

def monitorar_desempenho(func: F) -> F:
    """
    Decorador para monitorar tempo de execução de funções de aprendizado.
    Adiciona a chave '_tempo_execucao' ao dicionário de retorno.
    """
    @wraps(func)
    def wrapper(*args, **kwargs):
        inicio = time.perf_counter()
        resultado = func(*args, **kwargs)
        duracao = time.perf_counter() - inicio
        
        _logger.debug(f"Função {func.__name__} executada em {duracao:.4f} segundos")
        
        if isinstance(resultado, dict):
            resultado['_tempo_execucao'] = duracao
        return resultado
    return cast(F, wrapper)


def validar_dados_aprendizado(func: F) -> F:
    """
    Decorador para validar dados de entrada (primeiro argumento posicional)
    para funções de aprendizado.
    """
    @wraps(func)
    def wrapper(*args, **kwargs):
        if not args:
            raise ValueError("Nenhum argumento fornecido para validação.")
        
        dados = args[0]
        if dados is None:
            raise ValueError("Dados não podem ser None")
        
        if isinstance(dados, (list, tuple)) and len(dados) == 0:
            raise ValueError("Lista/tupla de dados não pode estar vazia")
        
        if hasattr(dados, '__len__') and len(dados) == 0 and not isinstance(dados, (str, bytes)):
            raise ValueError("Container de dados não pode estar vazio")
        
        return func(*args, **kwargs)
    return cast(F, wrapper)


