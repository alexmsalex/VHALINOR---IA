# Classes de fábrica e utilitárias
class SistemaAprendizadoFactory:
    """Fábrica para criação de sistemas de aprendizado."""
    
    @staticmethod
    def criar_sistema(tipo: str, config: Optional[Dict[str, Any]]=None) -> Union['AprendizadoContinuo', 'AprendizadoEvolucional']:
        """
        Cria um sistema de aprendizado baseado no tipo especificado.
        
        Args:
            tipo: 'continuo' ou 'evolucional'
            config: Configurações opcionais para o sistema
            
        Returns:
            Instância do sistema de aprendizado
            
        Raises:
            ValueError: Se o tipo for inválido
            ImportError: Se o módulo necessário não estiver disponível
        """
        config = config or {}
        
        if tipo.lower() == 'continuo':
            if not _APRENDIZADO_CONTINUO_AVAILABLE:
                raise ImportError("Módulo AprendizadoContinuo não disponível")
            return AprendizadoContinuo(**config)
        
        elif tipo.lower() == 'evolucional':
            if not _APRENDIZADO_EVOLUCIONAL_AVAILABLE:
                raise ImportError("Módulo AprendizadoEvolucional não disponível")
            return AprendizadoEvolucional(**config)
        
        else:
            raise ValueError(f"Tipo de sistema desconhecido: {tipo}. Use 'continuo' ou 'evolucional'")
    
    @staticmethod
    def criar_sistema_hibrido(config_continuo: Optional[Dict]=None,
                              config_evolucional: Optional[Dict]=None) -> 'SistemaAprendizadoHibrido':
        """
        Cria um sistema híbrido que combina aprendizado contínuo e evolucional.
        
        Args:
            config_continuo: Configuração para aprendizado contínuo
            config_evolucional: Configuração para aprendizado evolucional
            
        Returns:
            Sistema híbrido de aprendizado
        """
        from .hibrido import SistemaAprendizadoHibrido
        return SistemaAprendizadoHibrido(
            config_continuo=config_continuo,
            config_evolucional=config_evolucional
        )


class SistemaAprendizadoHibrido:
    """Sistema híbrido que combina aprendizado contínuo e evolucional."""
    
    def __init__(self, config_continuo: Optional[Dict]=None,
                 config_evolucional: Optional[Dict]=None):
        """
        Inicializa o sistema híbrido.
        
        Args:
            config_continuo: Configuração para aprendizado contínuo
            config_evolucional: Configuração para aprendizado evolucional
        """
        self.continuo = SistemaAprendizadoFactory.criar_sistema('continuo', config_continuo)
        self.evolucional = SistemaAprendizadoFactory.criar_sistema('evolucional', config_evolucional)
        self._logger = logging.getLogger(f"{__name__}.Hibrido")
    
    def processar(self, dados: Any, modo: str='ambos') -> Dict[str, Any]:
        """
        Processa dados usando os sistemas de aprendizado.
        
        Args:
            dados: Dados a serem processados
            modo: 'continuo', 'evolucional' ou 'ambos'
            
        Returns:
            Resultados do processamento
        """
        resultados = {}
        
        if modo in ['continuo', 'ambos']:
            resultados['continuo'] = self.continuo.aprender(dados)
        
        if modo in ['evolucional', 'ambos']:
            resultados['evolucional'] = self.evolucional.evoluir(dados)
        
        return resultados


