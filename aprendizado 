# Tipo para os sistemas de aprendizado
SistemaTipo = Union['AprendizadoContinuo', 'AprendizadoEvolucional']


class SistemaAprendizadoFactory:
    """Fábrica para criação de sistemas de aprendizado (padrão Singleton opcional)."""
    
    _instances: Dict[str, SistemaTipo] = {}
    _use_singleton = False
    
    @classmethod
    def configure(cls, use_singleton: bool = False) -> None:
        """
        Configura o comportamento da fábrica.
        
        Args:
            use_singleton: Se True, reutiliza instâncias já criadas para o mesmo tipo/config.
        """
        cls._use_singleton = use_singleton
    
    @classmethod
    def criar_sistema(cls, tipo: str, config: Optional[Dict[str, Any]] = None) -> SistemaTipo:
        """
        Cria (ou obtém) um sistema de aprendizado baseado no tipo especificado.
        
        Args:
            tipo: 'continuo' ou 'evolucional'
            config: Configurações opcionais para o sistema
            
        Returns:
            Instância do sistema de aprendizado
            
        Raises:
            ValueError: Se o tipo for inválido
            ImportError: Se o módulo necessário não estiver disponível
        """
        config = config or {}
        tipo = tipo.lower()
        
        if tipo == 'continuo':
            if not _APRENDIZADO_CONTINUO_AVAILABLE:
                raise ImportError("Módulo AprendizadoContinuo não disponível. Verifique as dependências.")
            if cls._use_singleton and 'continuo' in cls._instances:
                return cls._instances['continuo']
            instance = AprendizadoContinuo(**config)  # type: ignore
            if cls._use_singleton:
                cls._instances['continuo'] = instance
            return instance
        
        elif tipo == 'evolucional':
            if not _APRENDIZADO_EVOLUCIONAL_AVAILABLE:
                raise ImportError("Módulo AprendizadoEvolucional não disponível. Verifique as dependências.")
            if cls._use_singleton and 'evolucional' in cls._instances:
                return cls._instances['evolucional']
            instance = AprendizadoEvolucional(**config)  # type: ignore
            if cls._use_singleton:
                cls._instances['evolucional'] = instance
            return instance
        
        else:
            raise ValueError(f"Tipo de sistema desconhecido: {tipo}. Use 'continuo' ou 'evolucional'")
    
    @classmethod
    def criar_sistema_hibrido(cls,
                              config_continuo: Optional[Dict] = None,
                              config_evolucional: Optional[Dict] = None) -> 'SistemaAprendizadoHibrido':
        """
        Cria um sistema híbrido que combina aprendizado contínuo e evolucional.
        
        Args:
            config_continuo: Configuração para aprendizado contínuo
            config_evolucional: Configuração para aprendizado evolucional
            
        Returns:
            Sistema híbrido de aprendizado
        """
        return SistemaAprendizadoHibrido(
            config_continuo=config_continuo,
            config_evolucional=config_evolucional
        )


class SistemaAprendizadoHibrido:
    """
    Sistema híbrido que combina aprendizado contínuo e evolucional.
    Gerencia a interação entre os dois paradigmas.
    """
    
    def __init__(self,
                 config_continuo: Optional[Dict] = None,
                 config_evolucional: Optional[Dict] = None):
        """
        Inicializa o sistema híbrido.
        
        Args:
            config_continuo: Configuração para aprendizado contínuo
            config_evolucional: Configuração para aprendizado evolucional
        """
        self.continuo = SistemaAprendizadoFactory.criar_sistema('continuo', config_continuo)
        self.evolucional = SistemaAprendizadoFactory.criar_sistema('evolucional', config_evolucional)
        self._logger = logging.getLogger(f"{__name__}.Hibrido")
        self._logger.info("Sistema híbrido inicializado com sucesso.")
    
    def processar(self, dados: Any, modo: str = 'ambos') -> Dict[str, Any]:
        """
        Processa dados usando os sistemas de aprendizado.
        
        Args:
            dados: Dados a serem processados (formato depende dos subsistemas)
            modo: 'continuo', 'evolucional' ou 'ambos'
            
        Returns:
            Dicionário com resultados do processamento.
            Exemplo: {'continuo': {...}, 'evolucional': {...}}
        """
        resultados = {}
        
        if modo in ('continuo', 'ambos'):
            try:
                resultados['continuo'] = self.continuo.aprender(dados)
            except Exception as e:
                self._logger.error(f"Erro no aprendizado contínuo: {e}")
                resultados['continuo'] = {'erro': str(e)}
        
        if modo in ('evolucional', 'ambos'):
            try:
                resultados['evolucional'] = self.evolucional.evoluir(dados)
            except Exception as e:
                self._logger.error(f"Erro no aprendizado evolucional: {e}")
                resultados['evolucional'] = {'erro': str(e)}
        
        return resultados
    
    def get_estatisticas(self) -> Dict[str, Any]:
        """Retorna estatísticas consolidadas dos subsistemas."""
        stats = {}
        if hasattr(self.continuo, 'get_estatisticas'):
            stats['continuo'] = self.continuo.get_estatisticas()
        if hasattr(self.evolucional, 'get_estatisticas'):
            stats['evolucional'] = self.evolucional.get_estatisticas()
        return stats


