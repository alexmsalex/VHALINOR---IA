def _check_dependencies():
    """Verifica dependências necessárias."""
    missing_packages = []
    outdated_packages = []
    
    for package, min_version in _REQUIRED_PACKAGES.items():
        try:
            module = importlib.import_module(package)
            # Tenta obter a versão
            if hasattr(module, '__version__'):
                version = module.__version__
                # Comparação básica de versão
                from packaging import version as packaging_version
                if packaging_version.parse(version) < packaging_version.parse(min_version):
                    outdated_packages.append(f"{package} ({version} < {min_version})")
            elif hasattr(module, 'version'):
                version = module.version
                from packaging import version as packaging_version
                if packaging_version.parse(version) < packaging_version.parse(min_version):
                    outdated_packages.append(f"{package} ({version} < {min_version})")
        except ImportError:
            missing_packages.append(package)
    
    if missing_packages or outdated_packages:
        warning_msg = "Dependências do módulo de aprendizado:\n"
        if missing_packages:
            warning_msg += f"  Faltando: {', '.join(missing_packages)}\n"
        if outdated_packages:
            warning_msg += f"  Desatualizadas: {', '.join(outdated_packages)}\n"
        warning_msg += "  Instale com: pip install numpy scikit-learn pandas deap"
        _logger.warning(warning_msg)
        return False
    return True


