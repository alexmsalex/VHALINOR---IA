def _version_to_tuple(version_str: str) -> tuple:
    """Converte string de versão para tupla de inteiros para comparação."""
    import re
    # Remove sufixos como 'dev', 'rc', etc. e extrai apenas números
    clean = re.sub(r'([0-9]+(?:\\.[0-9]+)*).*', r'\\1', version_str)
    return tuple(int(x) for x in clean.split('.') if x.isdigit())


def _check_package_version(package_name: str, min_version: str) -> bool:
    """Verifica se um pacote está instalado e tem versão >= mínima."""
    try:
        module = importlib.import_module(package_name)
        # Tenta obter a versão de diferentes atributos comuns
        version_str = getattr(module, '__version__', None)
        if version_str is None:
            version_str = getattr(module, 'version', None)
        if version_str is None:
            # Para alguns pacotes como sklearn
            if package_name == 'scikit-learn':
                try:
                    from sklearn import __version__ as sk_version
                    version_str = sk_version
                except ImportError:
                    pass
        if version_str:
            return _version_to_tuple(version_str) >= _version_to_tuple(min_version)
        else:
            # Se não consegue determinar versão, assume que está ok
            _logger.warning(f"Não foi possível determinar a versão de {package_name}, assumindo compatível.")
            return True
    except ImportError:
        return False


def _check_dependencies() -> Dict[str, bool]:
    """
    Verifica todas as dependências necessárias.
    
    Returns:
        Dicionário com status de cada pacote (True se ok, False se faltando/desatualizado)
    """
    status = {}
    for package, min_version in _REQUIRED_PACKAGES.items():
        ok = _check_package_version(package, min_version)
        status[package] = ok
        if not ok:
            _logger.warning(
                f"Dependência {package} (>= {min_version}) não encontrada ou desatualizada. "
                f"Funcionalidades de aprendizado podem ser limitadas."
            )
    return status


