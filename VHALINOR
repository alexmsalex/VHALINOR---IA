class Position:
    """Gerencia uma posição aberta."""
    def __init__(self, symbol: str, entry_price: float, quantity: float, 
                 side: str, stop_loss: float, take_profit: float,
                 entry_time: datetime):
        self.symbol = symbol
        self.entry_price = entry_price
        self.quantity = quantity
        self.side = side  # 'long' or 'short'
        self.stop_loss = stop_loss
        self.take_profit = take_profit
        self.entry_time = entry_time
        self.highest_price = entry_price
        self.lowest_price = entry_price
        self.trailing_stop = None
    
    def update_trailing(self, current_price: float, activation_pct: float = 0.01, distance_pct: float = 0.005):
        """Atualiza trailing stop se aplicável."""
        if self.side == 'long':
            if current_price > self.highest_price:
                self.highest_price = current_price
                if self.highest_price >= self.entry_price * (1 + activation_pct):
                    new_stop = self.highest_price * (1 - distance_pct)
                    if new_stop > self.stop_loss:
                        self.stop_loss = new_stop
        else:  # short
            if current_price < self.lowest_price:
                self.lowest_price = current_price
                if self.lowest_price <= self.entry_price * (1 - activation_pct):
                    new_stop = self.lowest_price * (1 + distance_pct)
                    if new_stop < self.stop_loss:
                        self.stop_loss = new_stop
    
    def check_exit(self, current_price: float) -> Optional[str]:
        """Verifica se o preço atingiu stop loss ou take profit."""
        if self.side == 'long':
            if current_price <= self.stop_loss:
                return "stop_loss"
            if current_price >= self.take_profit:
                return "take_profit"
        else:
            if current_price >= self.stop_loss:
                return "stop_loss"
            if current_price <= self.take_profit:
                return "take_profit"
        return None
    
    def pnl_percent(self, current_price: float) -> float:
        """Retorna PnL percentual da posição."""
        if self.side == 'long':
            return (current_price - self.entry_price) / self.entry_price * 100
        else:
            return (self.entry_price - current_price) / self.entry_price * 100


class Vhalinor:
    """
    Agente autônomo de trading com personalidade adaptativa.
    """
    
    def __init__(self, config: TradingConfig):
        self.nome = "Vhalinor"
        self.config = config
        self.energia = 100.0  # % de disposição (simula fadiga)
        self.curiosidade = 0.8  # tendência a explorar sinais não convencionais
        self.memoria_trades = deque(maxlen=50)  # histórico de trades
        self.posicao_atual: Optional[Position] = None
        self.daily_pnl = 0.0
        self.daily_trades = 0
        self.consecutive_losses = 0
        
        # Inicializa componentes
        self.strategist = Strategist()
        self.exchange = self._init_exchange()
        
        logger.info(f"{self.nome} inicializado. Modo: {config.mode.value} | Símbolo: {config.symbol}")
    
    def _init_exchange(self):
        """Inicializa a exchange (ccxt) com base na configuração."""
        if not CCXT_AVAILABLE:
            raise RuntimeError("ccxt é necessário para operar. Instale com: pip install ccxt")
        
        exchange_class = getattr(ccxt, self.config.exchange.name)
        exchange = exchange_class({
            'apiKey': self.config.exchange.api_key,
            'secret': self.config.exchange.api_secret,
            'enableRateLimit': True,
            'options': self.config.exchange.options
        })
        
        if self.config.exchange.testnet:
            exchange.set_sandbox_mode(True)
        
        # Carrega mercados
        exchange.load_markets()
        return exchange
    
    def get_historical_data(self, limit: int = 200) -> pd.DataFrame:
        """Busca dados históricos OHLCV da exchange."""
        try:
            timeframe = self._convert_interval(self.config.interval)
            ohlcv = self.exchange.fetch_ohlcv(
                self.config.symbol,
                timeframe=timeframe,
                limit=limit
            )
            df = pd.DataFrame(ohlcv, columns=['timestamp', 'open', 'high', 'low', 'close', 'volume'])
            df['timestamp'] = pd.to_datetime(df['timestamp'], unit='ms')
            df.set_index('timestamp', inplace=True)
            return df
        except Exception as e:
            logger.error(f"Erro ao buscar dados: {e}")
            raise
    
    def _convert_interval(self, interval: str) -> str:
        """Converte intervalo do formato da VHALINOR para ccxt."""
        mapping = {
            "1m": "1m", "3m": "3m", "5m": "5m", "15m": "15m",
            "30m": "30m", "1h": "1h", "2h": "2h", "4h": "4h",
            "6h": "6h", "8h": "8h", "12h": "12h", "1d": "1d"
        }
        return mapping.get(interval, "5m")
    
    def calculate_indicators(self, df: pd.DataFrame) -> pd.DataFrame:
        """Calcula indicadores técnicos necessários para as estratégias."""
        # RSI
        df['rsi'] = ta.momentum.RSIIndicator(df['close'], window=14).rsi()
        # MACD
        macd = ta.trend.MACD(df['close'])
        df['macd'] = macd.macd()
        df['macd_signal'] = macd.macd_signal()
        df['macd_diff'] = macd.macd_diff()
