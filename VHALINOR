        df['ema_9'] = ta.trend.EMAIndicator(df['close'], window=9).ema_indicator()
        df['ema_21'] = ta.trend.EMAIndicator(df['close'], window=21).ema_indicator()
        df['sma_50'] = ta.trend.SMAIndicator(df['close'], window=50).sma_indicator()
        return df
    
    def decidir(self, signal_result: SignalResult) -> str:
        """
        Toma decisão final considerando estado interno (energia, curiosidade).
        Retorna mensagem descritiva.
        """
        if self.energia < 30:
            return f"{self.nome} está cansado (energia {self.energia:.1f}%) - pausando trades."
        
        # Curiosidade pode alterar o sinal (exploração)
        if random.random() < self.curiosidade * 0.15:
            logger.debug(f"{self.nome} está curioso e decidiu HOLD para explorar")
            return f"{self.nome}: Curiosidade alterou sinal para HOLD."
        
        # Verifica se já há posição aberta
        if self.posicao_atual is not None:
            # Se já tem posição, só fecha se sinal contrário com alta confiança
            if signal_result.signal in (SignalType.SELL, SignalType.CLOSE_LONG) and self.posicao_atual.side == 'long':
                return self._fechar_posicao(signal_result)
            elif signal_result.signal in (SignalType.BUY, SignalType.CLOSE_SHORT) and self.posicao_atual.side == 'short':
                return self._fechar_posicao(signal_result)
            else:
                return f"{self.nome}: Mantendo posição atual ({self.posicao_atual.side})."
        
        # Sem posição: abre nova se sinal for compra/venda
        if signal_result.signal == SignalType.BUY:
            return self._abrir_posicao('long', signal_result)
        elif signal_result.signal == SignalType.SELL:
            return self._abrir_posicao('short', signal_result)
        else:
            return f"{self.nome}: Sem sinal forte. Observando."
    
    def _abrir_posicao(self, side: str, signal: SignalResult) -> str:
        """Abre nova posição."""
        preco = self._get_current_price()
        if preco is None:
            return f"{self.nome}: Não foi possível obter preço atual."
        
        # Calcula quantidade baseada no risco
        capital = self._get_capital()
        if capital is None:
            capital = 10000.0  # fallback
        
        # Usa quantidade da config ou calcula baseado no stop loss
        if self.config.quantity:
            quantidade = self.config.quantity
        else:
            # Quantidade = (capital * risco_por_trade) / distância_stop
            risk_amount = capital * self.config.risk.risk_per_trade_pct
            stop_distance = abs(preco - signal.stop_loss) / preco if signal.stop_loss else 0.02
            if stop_distance > 0:
                quantidade = risk_amount / (preco * stop_distance)
            else:
                quantidade = (capital * self.config.risk.risk_per_trade_pct) / preco
        
        # Limita posição máxima
        max_qty = capital * self.config.risk.max_position_size_pct / preco
        quantidade = min(quantidade, max_qty)
        
        # Define stop loss e take profit (usa os da estratégia ou defaults)
        stop_loss = signal.stop_loss or (preco * (1 - 0.02) if side == 'long' else preco * (1 + 0.02))
        take_profit = signal.take_profit or (preco * (1 + 0.03) if side == 'long' else preco * (1 - 0.03))
        
        # Executa ordem (simulada ou real)
        if self.config.mode == TradingMode.LIVE:
            try:
                if side == 'long':
                    self.exchange.create_market_buy_order(self.config.symbol, quantidade)
                else:
                    self.exchange.create_market_sell_order(self.config.symbol, quantidade)
                logger.info(f"Ordem executada: {side.upper()} {quantidade} {self.config.symbol} @ {preco}")
            except Exception as e:
                logger.error(f"Erro ao executar ordem: {e}")
                return f"{self.nome}: Erro na execução da ordem."
        
        # Cria objeto Position
        self.posicao_atual = Position(
            symbol=self.config.symbol,
            entry_price=preco,
            quantity=quantidade,
            side=side,
            stop_loss=stop_loss,
            take_profit=take_profit,
            entry_time=datetime.now()
        )
        
        self.energia -= 3.0
        msg = f"{self.nome}: ABRIU {side.upper()} {quantidade:.4f} @ {preco:.2f} | SL: {stop_loss:.2f} | TP: {take_profit:.2f}"
        logger.info(msg)
        return msg
    
    def _fechar_posicao(self, signal: SignalResult) -> str:
        """Fecha posição atual."""
        if self.posicao_atual is None:
            return f"{self.nome}: Nenhuma posição para fechar."
        
        preco = self._get_current_price()
        if preco is None:
            return f"{self.nome}: Não foi possível obter preço atual."
        
        pnl_percent = self.posicao_atual.pnl_percent(preco)
        pnl_amount = (pnl_percent / 100) * (self.posicao_atual.quantity * self.posicao_atual.entry_price)
        
        # Executa ordem de fechamento
        if self.config.mode == TradingMode.LIVE:
            try:
                if self.posicao_atual.side == 'long':
                    self.exchange.create_market_sell_order(self.config.symbol, self.posicao_atual.quantity)
                else:
                    self.exchange.create_market_buy_order(self.config.symbol, self.posicao_atual.quantity)
            except Exception as e:
                logger.error(f"Erro ao fechar posição: {e}")
                return f"{self.nome}: Erro no fechamento."
        
        # Registra trade na memória
        trade_record = {
            'entry_time': self.posicao_atual.entry_time,
            'exit_time': datetime.now(),
            'side': self.posicao_atual.side,
            'entry_price': self.posicao_atual.entry_price,
            'exit_price': preco,
            'pnl_percent': pnl_percent,
            'pnl_amount': pnl_amount,
            'stop_loss': self.posicao_atual.stop_loss,
            'take_profit': self.posicao_atual.take_profit,
            'reason': signal.signal.value if signal else 'manual'
        }
        self.memoria_trades.append(trade_record)
        self.daily_pnl += pnl_amount
        self.daily_trades += 1
        
        if pnl_percent < 0:
            self.consecutive_losses += 1
            # Reduz curiosidade após perdas consecutivas
            self.curiosidade = max(0.3, self.curiosidade - 0.05)
        else:
            self.consecutive_losses = 0
            self.curiosidade = min(1.0, self.curiosidade + 0.02)
        
        # Atualiza energia
        self.energia += 5.0
        self.energia = min(100.0, self.energia)
        
        msg = f"{self.nome}: FECHOU {self.posicao_atual.side.upper()} @ {preco:.2f} | PnL: {pnl_percent:+.2f}% ({pnl_amount:+.2f})"
        logger.info(msg)
        
        self.posicao_atual = None
        return msg
    
    def _get_current_price(self) -> Optional[float]:
        """Obtém preço atual do símbolo."""
        try:
            ticker = self.exchange.fetch_ticker(self.config.symbol)
            return ticker['last']
        except Exception as e:
            logger.error(f"Erro ao obter preço: {e}")
            return None
    
    def _get_capital(self) -> Optional[float]:
        """Obtém capital disponível na conta (simulado ou real)."""
        if self.config.mode == TradingMode.PAPER:
            # Simulação: mantém saldo virtual
            if not hasattr(self, '_paper_balance'):
                self._paper_balance = 10000.0
            # Atualiza com PnL das posições (simplificado)
            if self.posicao_atual:
                current_price = self._get_current_price()
                if current_price:
                    unrealized_pnl = (current_price - self.posicao_atual.entry_price) * self.posicao_atual.quantity
                    return self._paper_balance + unrealized_pnl
            return self._paper_balance
        else:
            # Modo real: consulta saldo da exchange
            try:
                balance = self.exchange.fetch_balance()
                # Para futures, usar 'USDT' ou a moeda de cotação
                quote = self.config.symbol_quote
                return balance['total'].get(quote, 0)
            except:
                return None
    
    def _check_positions(self, df: pd.DataFrame):
        """Verifica se a posição atual deve ser fechada por stop/take."""
        if self.posicao_atual is None:
            return
        
        current_price = df['close'].iloc[-1]
        exit_reason = self.posicao_atual.check_exit(current_price)
        
        if exit_reason:
            logger.info(f"Posição fechada por {exit_reason}")
            # Cria um sinal artificial para fechamento
            fake_signal = SignalResult(
                signal=SignalType.CLOSE_LONG if self.posicao_atual.side == 'long' else SignalType.CLOSE_SHORT,
                confidence=100,
                metadata={'reason': exit_reason}
            )
            self._fechar_posicao(fake_signal)
        
        # Atualiza trailing stop se configurado
        if self.config.risk.use_trailing_stop and self.posicao_atual:
            self.posicao_atual.update_trailing(
                current_price,
                activation_pct=self.config.risk.trailing_stop_activation,
                distance_pct=self.config.risk.trailing_stop_distance
            )
    
    def run(self):
        """Loop principal do trading."""
        logger.info(f"Iniciando loop principal de trading. Modo: {self.config.mode.value}")
        
        # Para backtest, implementar lógica separada (simplificada aqui)
        if self.config.mode == TradingMode.BACKTEST:
            logger.info("Modo backtest não implementado neste exemplo. Use o módulo específico.")
            return
        
        while True:
            try:
                # 1. Coletar dados
                df = self.get_historical_data(limit=200)
                df = self.calculate_indicators(df)
                
                # 2. Selecionar melhores estratégias
                top_strategies = self.strategist.select_best_strategies(df, top_n=self.config.strategy.top_n_strategies)
                
                if not top_strategies:
                    logger.debug("Nenhuma estratégia selecionada. Aguardando...")
                    time.sleep(60)
                    continue
                
                # 3. Obter sinal da melhor estratégia (ou combinar)
                best = top_strategies[0]
                signal_result = SignalResult(
                    signal=SignalType(best['signal']['signal']),
                    confidence=best['score'],
                    stop_loss=best['signal'].get('stop_loss'),
                    take_profit=best['signal'].get('take_profit'),
                    reasoning=best.get('reasoning', [])
                )
                
                # 4. Verificar confiança mínima
                if signal_result.confidence < self.config.strategy.min_confidence:
                    logger.debug(f"Confiança {signal_result.confidence:.1f}% < mínimo {self.config.strategy.min_confidence}%")
                    time.sleep(60)
                    continue
                
                # 5. Decisão final do agente
                msg = self.decidir(signal_result)
                logger.info(msg)
                
                # 6. Verificar posições abertas (stop/take)
                self._check_positions(df)
                
                # 7. Aguardar próximo intervalo
                sleep_seconds = self._interval_to_seconds(self.config.interval)
                time.sleep(sleep_seconds)
                
            except KeyboardInterrupt:
                logger.info("Sinal de interrupção recebido. Encerrando...")
                break
            except Exception as e:
                logger.error(f"Erro no loop principal: {e}", exc_info=True)
                time.sleep(60)
    
    def _interval_to_seconds(self, interval: str) -> int:
        """Converte intervalo para segundos."""
        mapping = {
            "1m": 60, "3m": 180, "5m": 300, "15m": 900,
            "30m": 1800, "1h": 3600, "2h": 7200, "4h": 14400
        }
        return mapping.get(interval, 60)


