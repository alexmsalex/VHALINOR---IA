# Configurações do Ambiente VHALINOR AI Geral
# ==========================================
# Copie este arquivo para .env e ajuste os valores conforme necessário

# Configurações Básicas
APP_NAME=VHALINOR AI Geral
APP_VERSION=6.0.0
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# Configurações do Servidor
HOST=127.0.0.1
PORT=8000
WORKERS=1
RELOAD=true

# Segurança
SECRET_KEY=vhalinor-secret-key-change-in-production
ALLOWED_HOSTS=*
CORS_ORIGINS=*

# Banco de Dados
DATABASE_TYPE=sqlite
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=vhalinor_db
DATABASE_USER=vhalinor
# DATABASE_PASSWORD=your_password_here

# Cache
CACHE_BACKEND=memory
CACHE_TTL=3600

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=your_redis_password
REDIS_MAX_CONNECTIONS=10

# Logging
LOG_FILE=logs/vhalinor.log
LOG_MAX_SIZE=10MB
LOG_BACKUP_COUNT=5

# Machine Learning
ML_MODEL_PATH=models/
ML_MODEL_NAME=vhalinor_model
ML_DEVICE=cpu
ML_BATCH_SIZE=32
ML_LEARNING_RATE=0.001
ML_EPOCHS=100

# Processamento de Linguagem Natural
NLP_MODEL_NAME=bert-base-uncased
NLP_MAX_LENGTH=512
NLP_BATCH_SIZE=16

# Visão Computacional
CV_MODEL_PATH=models/cv/
CV_IMAGE_SIZE=(224, 224)
CV_BATCH_SIZE=16

# Trading e Finanças
# TRADING_API_KEY=your_api_key_here
# TRADING_API_SECRET=your_api_secret_here
TRADING_BASE_URL=https://api.binance.com
TRADING_SYMBOLS=BTCUSDT,ETHUSDT
TRADING_TIMEFRAME=1h
TRADING_MAX_POSITIONS=5
TRADING_RISK_PER_TRADE=0.02

# WebSocket e Tempo Real
WEBSOCKET_ENABLED=true
WEBSOCKET_PORT=8001
REAL_TIME_DATA_SOURCES=binance,yfinance,alpha_vantage

# Automação
AUTOMATION_ENABLED=true
AUTOMATION_INTERVAL=60
# SELENIUM_DRIVER_PATH=/path/to/chromedriver
SELENIUM_HEADLESS=true
PYAUTOGUI_FAIL_SAFE=true

# Blockchain e Web3
WEB3_ENABLED=false
# WEB3_PROVIDER_URL=https://mainnet.infura.io/v3/YOUR-PROJECT-ID
# WEB3_PRIVATE_KEY=your_private_key_here
WEB3_GAS_LIMIT=21000
WEB3_GAS_PRICE=20

# Monitoramento e Métricas
METRICS_ENABLED=true
METRICS_PORT=9090
HEALTH_CHECK_INTERVAL=30

# Armazenamento de Arquivos
UPLOAD_DIR=uploads/
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=.pdf,.txt,.csv,.json,.xlsx,.jpg,.png

# APIs Externas
# OPENAI_API_KEY=your_openai_key_here
# ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here
# NEWS_API_KEY=your_news_api_key_here

# Desenvolvimento e Teste
TESTING_ENABLED=false
MOCK_EXTERNAL_APIS=false
TEST_DATA_PATH=tests/data/

# Performance
MAX_CONCURRENT_REQUESTS=100
REQUEST_TIMEOUT=30
CONNECTION_POOL_SIZE=10

# Segurança Avançada
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=3600

# Backup e Recuperação
BACKUP_ENABLED=true
BACKUP_INTERVAL=86400
BACKUP_RETENTION_DAYS=30
BACKUP_PATH=backups/
